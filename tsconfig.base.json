{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@shrimpworks/core": ["packages/core/src"],
      "@shrimpworks/agents": ["packages/agents/src"],
      "@shrimpworks/workflows": ["packages/workflows/src"],
      "@shrimpworks/tasks": ["packages/tasks/src"],
      "@shrimpworks/execution": ["packages/execution/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}
