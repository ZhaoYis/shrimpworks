# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shrimpworks?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# API
API_PORT=3001
API_PREFIX="api/v1"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Provider (Anthropic)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# AI Provider (OpenAI) - Alternative
# OPENAI_API_KEY="your-openai-api-key"

# LLM Configuration
LLM_PROVIDER="anthropic"
LLM_MODEL="claude-sonnet-4-6"
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Storage
STORAGE_TYPE="local"
UPLOAD_DIR="./uploads"

# Email (optional)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Monitoring
LOG_LEVEL="info"
SENTRY_DSN=""

# Docker
DOCKER_REGISTRY="your-registry.com"
DOCKER_USERNAME=""
DOCKER_PASSWORD=""
